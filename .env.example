# ThoughtSpot host URL — used by both the frontend SDK and the token server
# Example: https://your-instance.thoughtspot.cloud
VITE_TS_HOST=https://yourTScluster.cloud

# Worksheet / Model GUID to load in Spotter
VITE_TS_WORKSHEET_ID=

# --- Server-side only (never exposed to the browser) ---

# The same ThoughtSpot host, used by the Express token server to call the REST API
TS_HOST=https://yourTScluster.cloud

# ThoughtSpot username to authenticate as
TS_USERNAME=user@domain.com

# Org identifier (name or numeric ID) for multi-tenant clusters (use 0 for Primary org)
TS_ORG_IDENTIFIER=

# Trusted auth secret key — generate this in Develop > Security Settings
TS_SECRET_KEY=

# Port for the Express token server (default: 3001)
PORT=3001
